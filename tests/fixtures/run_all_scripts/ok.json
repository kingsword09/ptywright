{
  "$schema": "../../../schemas/ptywright-script.schema.json",
  "launch": {
    "command": "bun",
    "args": ["-e", "console.log('ok')"],
    "cols": 80,
    "rows": 20
  },
  "trace": { "saveCast": false, "saveReport": false },
  "steps": [
    { "type": "waitForExit", "timeoutMs": 10000, "exitCode": 0 },
    {
      "type": "snapshot",
      "kind": "text",
      "scope": "buffer",
      "trimRight": true,
      "trimBottom": true,
      "saveAs": "out"
    },
    { "type": "expect", "from": "out", "contains": ["ok"] }
  ]
}
