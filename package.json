{
  "name": "ptywright",
  "version": "0.1.0",
  "private": true,
  "description": "Terminal/TUI automation driver over PTY + xterm, exposed as MCP tools",
  "keywords": [
    "agent",
    "automation",
    "mcp",
    "playwright",
    "pty",
    "terminal",
    "testing",
    "tui"
  ],
  "homepage": "https://github.com/kingsword09/ptywright/tree/main#readme",
  "bugs": {
    "url": "https://github.com/kingsword09/ptywright/issues"
  },
  "license": "Apache-2.0",
  "author": "Kingsword kingsword09 <kingsword09@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kingsword09/ptywright.git"
  },
  "type": "module",
  "scripts": {
    "dev": "bun run src/index.ts",
    "test": "bun test",
    "lint": "oxlint --type-aware --type-check .",
    "format": "oxfmt src tests package.json tsconfig.json .oxlintrc.json .oxfmtrc.json",
    "format:check": "oxfmt --check src tests package.json tsconfig.json .oxlintrc.json .oxfmtrc.json",
    "trace:report": "bun run src/trace/report.ts",
    "trace:cast-to-txt": "bun run src/trace/cast_to_txt.ts",
    "scenario:run": "bun run src/scenario/run.ts",
    "script:run": "bun run src/scenario/run.ts",
    "scenario:run-all": "bun run src/scenario/run_all.ts",
    "script:run-all": "bun run src/scenario/run_all.ts",
    "scenario:m5-mask-demo": "bun run src/scenario/run.ts scripts/m5_mask_demo.json",
    "script:m5-mask-demo": "bun run src/scenario/run.ts scripts/m5_mask_demo.json"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.2",
    "@xterm/headless": "^6.0.0",
    "bun-pty": "^0.4.7",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "bun-types": "^1.3.6",
    "oxfmt": "^0.24.0",
    "oxlint": "^1.39.0",
    "oxlint-tsgolint": "^0.11.1",
    "typescript": "^5.9.2"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "packageManager": "bun@1.3.6"
}
