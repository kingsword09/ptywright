{
  "name": "ptywright",
  "version": "0.1.0",
  "private": true,
  "description": "Terminal/TUI automation driver over PTY + xterm, exposed as MCP tools",
  "keywords": [
    "agent",
    "automation",
    "mcp",
    "playwright",
    "pty",
    "terminal",
    "testing",
    "tui"
  ],
  "homepage": "https://github.com/kingsword09/ptywright/tree/main#readme",
  "bugs": {
    "url": "https://github.com/kingsword09/ptywright/issues"
  },
  "license": "Apache-2.0",
  "author": "Kingsword kingsword09 <kingsword09@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kingsword09/ptywright.git"
  },
  "type": "module",
  "scripts": {
    "dev": "bun run src/index.ts",
    "test": "bun test",
    "codex:help-test": "bun run src/codex/extract_mcp_tool_text.ts --prompt prompts/codex_help_test.prompt --tool snapshot_view --out .tmp/codex_help_test.last.txt --jsonl .tmp/codex_help_test.jsonl --stderr .tmp/codex_help_test.stderr.log --print",
    "codex:ansi-color-demo": "bun run src/codex/extract_mcp_tool_text.ts --prompt prompts/ansi_color_demo.prompt --tool snapshot_view_ansi --out .tmp/ansi_color_demo.last.txt --jsonl .tmp/codex_ansi_color_demo.jsonl --stderr .tmp/codex_ansi_color_demo.stderr.log --print",
    "lint": "oxlint --type-aware --type-check .",
    "format": "oxfmt src tests package.json tsconfig.json .oxlintrc.json .oxfmtrc.json",
    "format:check": "oxfmt --check src tests package.json tsconfig.json .oxlintrc.json .oxfmtrc.json",
    "codex:trace-demo": "bun run src/codex/extract_mcp_tool_text.ts --prompt prompts/trace_demo_cast.prompt --tool snapshot_cast --out .tmp/trace_demo.cast --jsonl .tmp/codex_trace_demo.jsonl --stderr .tmp/codex_trace_demo.stderr.log --print-tail-lines 30",
    "codex:trace-demo:txt": "bun run codex:trace-demo && bun run src/trace/cast_to_txt.ts .tmp/trace_demo.cast",
    "trace:report": "bun run src/trace/report.ts",
    "trace:report-demo": "bun run src/trace/report.ts .tmp/trace_demo.cast",
    "trace:cast-to-txt": "bun run src/trace/cast_to_txt.ts",
    "codex:trace-demo:report": "bun run codex:trace-demo && bun run trace:report-demo",
    "codex:trace-demo:marked": "bun run src/codex/extract_mcp_tool_text.ts --prompt prompts/trace_demo_cast_marked.prompt --tool snapshot_cast --out .tmp/trace_demo_marked.cast --jsonl .tmp/codex_trace_demo_marked.jsonl --stderr .tmp/codex_trace_demo_marked.stderr.log --print-tail-lines 30",
    "trace:report-demo:marked": "bun run src/trace/report.ts .tmp/trace_demo_marked.cast",
    "codex:trace-demo:report:marked": "bun run codex:trace-demo:marked && bun run trace:report-demo:marked",
    "codex:mouse-click-demo": "bun run src/codex/extract_mcp_tool_text.ts --prompt prompts/mouse_click_demo.prompt --tool snapshot_view --out .tmp/mouse_click_demo.last.txt --jsonl .tmp/codex_mouse_click_demo.jsonl --stderr .tmp/codex_mouse_click_demo.stderr.log --print",
    "codex:ansi-color-demo:cast": "bun run src/codex/extract_mcp_tool_text.ts --prompt prompts/ansi_color_demo_cast.prompt --tool snapshot_cast --out .tmp/ansi_color_demo.cast --jsonl .tmp/codex_ansi_color_demo_cast.jsonl --stderr .tmp/codex_ansi_color_demo_cast.stderr.log --print-tail-lines 30",
    "trace:report-demo:ansi-color": "bun run src/trace/report.ts .tmp/ansi_color_demo.cast",
    "codex:ansi-color-demo:report": "bun run codex:ansi-color-demo:cast && bun run trace:report-demo:ansi-color",
    "codex:m5-mask-demo": "bun run src/codex/extract_mcp_tool_text.ts --prompt prompts/m5_mask_demo.prompt --tool snapshot_view --out .tmp/m5_mask_demo.last.txt --jsonl .tmp/codex_m5_mask_demo.jsonl --stderr .tmp/codex_m5_mask_demo.stderr.log --print",
    "scenario:run": "bun run src/scenario/run.ts",
    "script:run": "bun run src/scenario/run.ts",
    "scenario:run-all": "bun run src/scenario/run_all.ts",
    "script:run-all": "bun run src/scenario/run_all.ts",
    "scenario:m5-mask-demo": "bun run src/scenario/run.ts scripts/m5_mask_demo.json",
    "script:m5-mask-demo": "bun run src/scenario/run.ts scripts/m5_mask_demo.json"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.2",
    "@xterm/headless": "^6.0.0",
    "bun-pty": "^0.4.7",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "bun-types": "^1.3.6",
    "oxfmt": "^0.24.0",
    "oxlint": "^1.39.0",
    "oxlint-tsgolint": "^0.11.1",
    "typescript": "^5.9.2"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "packageManager": "bun@1.3.6"
}
