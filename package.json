{
  "name": "ptywright",
  "version": "0.1.1",
  "description": "Terminal/TUI automation driver over PTY + xterm, exposed as MCP tools",
  "keywords": [
    "agent",
    "automation",
    "mcp",
    "playwright",
    "pty",
    "terminal",
    "testing",
    "tui"
  ],
  "homepage": "https://github.com/kingsword09/ptywright/tree/main#readme",
  "bugs": {
    "url": "https://github.com/kingsword09/ptywright/issues"
  },
  "license": "Apache-2.0",
  "author": "Kingsword kingsword09 <kingsword09@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kingsword09/ptywright.git"
  },
  "bin": {
    "ptywright": "bin/ptywright"
  },
  "files": [
    "bin",
    "src",
    "schemas",
    "skills",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "src/cli.ts",
  "exports": {
    ".": "./src/cli.ts",
    "./agent": "./src/agent/runner.ts",
    "./mcp": "./src/mcp/server.ts",
    "./session": "./src/session/terminal_session.ts",
    "./script": "./src/script/runner.ts"
  },
  "scripts": {
    "dev": "vp dev",
    "mcp": "bun run src/index.ts",
    "agent": "bun run src/cli.ts agent",
    "test": "bun test",
    "test:mcp-all-tools": "bun test tests/mcp_all_tools_smoke.test.ts",
    "lint": "vp lint src tests examples package.json tsconfig.json vite.config.ts",
    "format": "vp fmt src tests examples package.json tsconfig.json vite.config.ts '!tests/fixtures/**' '!tests/golden/**' '!tests/agent-snapshots/**'",
    "format:check": "vp fmt --check src tests examples package.json tsconfig.json vite.config.ts '!tests/fixtures/**' '!tests/golden/**' '!tests/agent-snapshots/**'",
    "trace:report": "bun run src/trace/report.ts",
    "trace:cast-to-txt": "bun run src/trace/cast_to_txt.ts",
    "script:run": "bun run src/script/run.ts",
    "script:run-all": "bun run src/script/run_all.ts",
    "script:m5-mask-demo": "bun run src/script/run.ts scripts/m5_mask_demo.json",
    "prepublishOnly": "bun run format:check && bun run lint && bun test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.2",
    "@xterm/headless": "^6.0.0",
    "asciinema-player": "3.9.0",
    "bun-pty": "^0.4.7",
    "playwright": "^1.60.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "bun-types": "^1.3.6",
    "typescript": "^5.9.2",
    "vite": "^8.0.14",
    "vite-plus": "^0.1.22",
    "vitest": "^4.1.7"
  },
  "engines": {
    "bun": ">=1.3.6"
  },
  "packageManager": "bun@1.3.6"
}
