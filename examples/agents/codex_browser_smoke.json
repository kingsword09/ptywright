{
  "$schema": "../../schemas/ptywright-agent.schema.json",
  "name": "codex_browser_smoke",
  "artifactsDir": ".tmp/agent/codex_browser_smoke",
  "snapshotDir": "tests/agent-snapshots/codex_browser_smoke",
  "launch": {
    "mode": "command",
    "agentFlavor": "codex",
    "command": "your-browser-terminal-launcher",
    "args": ["--agent", "codex", "--print-url"],
    "waitForUrlMs": 15000
  },
  "viewports": [
    { "name": "desktop", "width": 1280, "height": 820 },
    { "name": "mobile", "width": 390, "height": 844, "isMobile": true, "hasTouch": true }
  ],
  "defaults": {
    "timeoutMs": 45000,
    "screenshot": true
  },
  "steps": [
    { "type": "waitForStableDom", "timeoutMs": 45000, "quietMs": 600, "intervalMs": 150 },
    { "type": "snapshot", "name": "launch", "targets": ["terminal", "dom", "screenshot"] }
  ]
}
