{
  "$schema": "../../schemas/ptywright-script.schema.json",
  "launch": {
    "command": "codex",
    "args": ["features", "list"],
    "env": {
      "HOME": ".tmp/ptywright-codex-home",
      "USERPROFILE": ".tmp/ptywright-codex-home"
    },
    "cols": 120,
    "rows": 40
  },
  "steps": [
    { "type": "waitForExit", "timeoutMs": 20000, "exitCode": 0 },
    {
      "type": "snapshot",
      "kind": "text",
      "scope": "buffer",
      "trimRight": true,
      "trimBottom": true,
      "saveAs": "out"
    },
    { "type": "expect", "from": "out", "contains": ["shell_tool"] }
  ]
}

