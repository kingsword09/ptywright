{
  "$schema": "../../schemas/ptywright-script.schema.json",
  "launch": {
    "command": "codex",
    "args": [
      "--no-alt-screen",
      "-c",
      "tui.animations=false",
      "-c",
      "tui.show_tooltips=false"
    ],
    "env": {
      "HOME": ".tmp/ptywright-codex-home",
      "USERPROFILE": ".tmp/ptywright-codex-home"
    },
    "cols": 100,
    "rows": 28
  },
  "steps": [
    {
      "type": "waitForText",
      "scope": "visible",
      "regex": "Welcome\\s+to\\s+Codex",
      "timeoutMs": 20000
    },
    { "type": "waitForStableScreen", "timeoutMs": 20000, "quietMs": 300 },
    {
      "type": "snapshot",
      "kind": "text",
      "scope": "visible",
      "trimRight": true,
      "trimBottom": true,
      "saveAs": "welcome"
    },
    {
      "type": "expect",
      "from": "welcome",
      "contains": ["Welcome to Codex", "Sign in with ChatGPT", "> 1."]
    },
    { "type": "pressKey", "key": "Down" },
    { "type": "waitForStableScreen", "timeoutMs": 20000, "quietMs": 250 },
    {
      "type": "snapshot",
      "kind": "text",
      "scope": "visible",
      "trimRight": true,
      "trimBottom": true,
      "saveAs": "down"
    },
    { "type": "expect", "from": "down", "contains": ["> 2.", "Provide your own API key"] },
    { "type": "pressKey", "key": "Ctrl+C" },
    { "type": "waitForExit", "timeoutMs": 20000 }
  ]
}

